# Google service-account JSON, base64-encoded. REQUIRED. Empty = auth dead.
# Generate: base64 -w0 service-account.json
CREDENTIALS_CONFIG=

# GCP project id the service account belongs to.
GOOGLE_PROJECT_ID=your-gcp-project-id

# --- OPTIONAL: auth gateway (only for the `secure` compose profile) ---
# Leave blank for local-only use. Required if you run `--profile secure`.
# Generate a strong token: openssl rand -hex 32
MCP_AUTH_TOKEN=
# Hostname for automatic HTTPS. Blank = plain HTTP on AUTH_PORT (token only).
DOMAIN=
# Public port for the gateway when DOMAIN is blank (plain HTTP).
AUTH_PORT=8080
